# ─────────────────────────────────────────────────────────────────────────────
# EC2 runtime config — contains NO AWS credentials.
# The EC2 instance role supplies AWS credentials via the metadata service.
#
# You do not normally write this file by hand: `deploy.sh` generates it from
# your `.env` and ships it to the instance. It is shown here for reference.
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=<long_random_string>
AWS_REGION=us-east-1
BEDROCK_KB_ID=<generated_by_setup_aws.sh>
BEDROCK_KB_DS_ID=<generated_by_setup_aws.sh>
S3_BUCKET_NAME=<your_bucket_name>
S3_RECIPES_PREFIX=recipes/
# Use the CLUSTER writer endpoint — IAM token auth from an EC2 role only
# validates against the cluster endpoint, not the instance endpoint.
RDS_HOST=<your-cluster-writer-endpoint>
RDS_PORT=5432
RDS_DB=postgres
RDS_USER=postgres
