# ─────────────────────────────────────────────────────────────────────────────
# Smart Cookbook — configuration
#
# 1. Copy this file to `.env`      →   cp .env.example .env
# 2. Fill in the values marked <...>
# 3. Run   ./setup_aws.sh          →   provisions the AWS resources below and
#                                      writes the generated IDs back into `.env`.
#
# You supply by hand: the two AWS keys, the Gemini key (for recipe images),
# a bucket name, and a DB master password. Everything else is filled in for you.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────────────────────
# Any long random string.  openssl rand -hex 32
SECRET_KEY=<long_random_string>

# ── AWS credentials (IAM user with admin-ish rights for the one-time setup) ────
AWS_ACCESS_KEY_ID=<your_iam_user_access_key>
AWS_SECRET_ACCESS_KEY=<your_iam_user_secret_key>
AWS_REGION=us-east-1

# ── Gemini — recipe image generation (Nano Banana) ───────────────────────────
# Get a key at https://aistudio.google.com/apikey . Without it the app runs fine
# but recipe images are simply skipped.
GEMINI_API_KEY=<your_gemini_api_key>
GEMINI_MODEL=gemini-3.1-flash-image

# ── S3 (recipe store + Knowledge Base data source) ───────────────────────────
# Pick a globally-unique bucket name; setup_aws.sh creates it if missing.
S3_BUCKET_NAME=<your-globally-unique-bucket-name>
S3_RECIPES_PREFIX=recipes/

# ── Aurora PostgreSQL master password ────────────────────────────────────────
# Used ONCE by setup_aws.sh to create the cluster and grant rds_iam. The running
# app never uses it — it authenticates with short-lived IAM tokens.
RDS_MASTER_PASSWORD=<choose_a_strong_password>

# ── EC2 deploy ───────────────────────────────────────────────────────────────
KEY_NAME=<your_ec2_key_pair_name>

# ─────────────────────────────────────────────────────────────────────────────
# Filled in automatically by setup_aws.sh — leave blank.
# ─────────────────────────────────────────────────────────────────────────────
BEDROCK_KB_ID=
BEDROCK_KB_DS_ID=
RDS_HOST=
RDS_PORT=5432
RDS_DB=postgres
RDS_USER=postgres

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL advanced features — safe to leave blank (each degrades gracefully).
# ─────────────────────────────────────────────────────────────────────────────
# Bedrock Agent-powered chat (falls back to plain Nova Lite + KB if unset):
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
AGENT_TOOL_SECRET=
APP_BASE_URL=
METEOSOURCE_API_KEY=
# Cooking-buddies email sharing (SES-verified sender + deployed Lambda):
SES_FROM_EMAIL=
BUDDY_EMAIL_LAMBDA_NAME=cooking-rag-buddy-email
