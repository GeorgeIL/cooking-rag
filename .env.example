# ─────────────────────────────────────────────────────────────────────────────
# Smart Cookbook — configuration
#
# 1. Copy this file to `.env`      →   cp .env.example .env
# 2. Fill in the values marked <...>
# 3. Run   ./setup_aws.sh          →   provisions every AWS resource below and
#                                      writes the generated IDs back into `.env`.
#
# The ONLY values you must supply by hand are the two AWS keys and (optionally)
# a bucket name and a DB master password. Everything else is filled in for you.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────────────────────
# Any long random string. Generate one with:  openssl rand -hex 32
SECRET_KEY=<long_random_string>

# ── AWS credentials (an IAM user with admin-ish rights for the one-time setup) ─
AWS_ACCESS_KEY_ID=<your_iam_user_access_key>
AWS_SECRET_ACCESS_KEY=<your_iam_user_secret_key>
AWS_REGION=us-east-1

# ── S3 (recipe store + Knowledge Base data source) ───────────────────────────
# Pick a globally-unique bucket name; setup_aws.sh creates it if missing.
S3_BUCKET_NAME=<your-globally-unique-bucket-name>
S3_RECIPES_PREFIX=recipes/

# ── Aurora PostgreSQL master password ────────────────────────────────────────
# Used ONCE by setup_aws.sh to create the cluster and grant the rds_iam role.
# The running app never uses it — it authenticates with short-lived IAM tokens.
RDS_MASTER_PASSWORD=<choose_a_strong_password>

# ─────────────────────────────────────────────────────────────────────────────
# Everything below is filled in automatically by setup_aws.sh — leave blank.
# ─────────────────────────────────────────────────────────────────────────────
BEDROCK_KB_ID=
BEDROCK_KB_DS_ID=
RDS_HOST=
RDS_PORT=5432
RDS_DB=postgres
RDS_USER=postgres
